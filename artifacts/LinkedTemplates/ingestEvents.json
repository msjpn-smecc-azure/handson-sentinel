{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "ArtifactsLocation": {
            "type": "string",
            "metadata": {
                "description": "Base location of deployment artifacts"
            }
        },
        "WorkspaceId": {
            "type": "secureString",
            "metadata": {
                "description": "Name for the Log Analytics workspace"
            }
        },
        "SharedKey": {
            "type": "secureString",
            "metadata": {
                "description": "Workspace key"
            }
        }
    },
    "functions": [],
    "variables": {
        "identityName": "[concat('userIdentity',uniqueString(resourceGroup().id))]",
        "deploymentScriptStorageAccountName": "[concat('dss', uniqueString(resourceGroup().id, 'ingestevents'))]",
        "storageAccountContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '17d1049b-9a84-46fb-8f53-869881c3d3ab')]"
    },
    "resources": [
        {
            "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
            "apiVersion": "2023-01-31",
            "name": "[variables('identityName')]",
            "location": "[resourceGroup().location]"
        },
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-05-01",
            "name": "[variables('deploymentScriptStorageAccountName')]",
            "location": "[resourceGroup().location]",
            "tags": {
                "SecureControl": "Ignore"
            },
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "allowSharedKeyAccess": false
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('deploymentScriptStorageAccountName')), variables('identityName'), variables('storageAccountContributorRoleId'))]",
            "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('deploymentScriptStorageAccountName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('deploymentScriptStorageAccountName'))]"
            ],
            "properties": {
                "roleDefinitionId": "[variables('storageAccountContributorRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName')), '2023-01-31').principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.Resources/deploymentScripts",
            "apiVersion": "2020-10-01",
            "name": "runPowerShellInline",
            "location": "[resourceGroup().location]",
            "kind": "AzurePowerShell",
            "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                    "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))]": {}
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.Storage/storageAccounts', variables('deploymentScriptStorageAccountName')), variables('identityName'), variables('storageAccountContributorRoleId')))]"
            ],
            "properties": {
                "forceUpdateTag": "1",
                "azPowerShellVersion": "10.0",
                "storageAccountSettings": {
                    "storageAccountName": "[variables('deploymentScriptStorageAccountName')]"
                },
                "environmentVariables": [
                    {
                      "name": "CustomerId",
                      "value": "[parameters('workspaceId')]"
                    },
                    {
                      "name": "SharedKey",
                      "secureValue": "[parameters('SharedKey')]"
                    }
                  ],
                "primaryScriptUri": "[uri(parameters('ArtifactsLocation'), 'artifacts/Scripts/IngestCSV.ps1')]",
                "supportingScriptUris": [],
                "timeout": "PT30M",
                "cleanupPreference": "Always",
                "retentionInterval": "P1D"
            }
        }
    ],
    "outputs": {}
}
