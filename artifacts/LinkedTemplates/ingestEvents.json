{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "ArtifactsLocation": {
            "type": "string",
            "metadata": {
                "description": "Base URL for the repository where the artifacts are stored"
            }
        },
        "WorkspaceId": {
            "type": "secureString",
            "metadata": {
                "description": "Name for the Log Analytics workspace"
            }
        },
        "SharedKey": {
            "type": "secureString",
            "metadata": {
                "description": "Workspace key"
            }
        }
    },
    "functions": [],
    "variables": {
        "identityName": "[concat('userIdentity',uniqueString(resourceGroup().id))]",
        "deploymentScriptStorageAccountName": "[concat('xxxsa', uniqueString(resourceGroup().id))]",
        "deploymentScriptName": "[concat('xxxds', uniqueString(resourceGroup().id))]"
    },
    "resources": [
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-05-01",
            "name": "[variables('deploymentScriptStorageAccountName')]",
            "location": "[resourceGroup().location]",
            "tags": {
                "SecurityControl": "Ignore"
            },
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "allowSharedKeyAccess": true
            }
        },
        {
            "type": "Microsoft.Resources/deploymentScripts",
            "apiVersion": "2020-10-01",
            "name": "[variables('deploymentScriptName')]",
            "location": "[resourceGroup().location]",
            "kind": "AzurePowerShell",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('deploymentScriptStorageAccountName'))]"
            ],
            "properties": {
                "forceUpdateTag": "1",
                "azPowerShellVersion": "10.0",
                "storageAccountSettings": {
                    "storageAccountName": "[variables('deploymentScriptStorageAccountName')]",
                    "storageAccountKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('deploymentScriptStorageAccountName')), '2023-05-01').keys[0].value]"
                },
                "environmentVariables": [
                    {
                      "name": "CustomerId",
                      "value": "[parameters('workspaceId')]"
                    },
                    {
                      "name": "SharedKey",
                      "secureValue": "[parameters('SharedKey')]"
                    },
                    {
                      "name": "ArtifactsLocation",
                      "value": "[parameters('ArtifactsLocation')]"
                    }
                  ],
                "primaryScriptUri": "[uri(parameters('ArtifactsLocation'), 'artifacts/Scripts/IngestCSV.ps1')]",
                "supportingScriptUris": [],
                "timeout": "PT30M",
                "cleanupPreference": "Always",
                "retentionInterval": "P1D"
            }
        }
    ],
    "outputs": {}
}
